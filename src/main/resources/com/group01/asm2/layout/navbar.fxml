<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.Group?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.group01.asm2.controllers.NavbarController"
      stylesheets="@../styles/layout/navbar.css"
      styleClass="navbar-container"
      spacing="6">

    <HBox fx:id="titleBar" alignment="CENTER_LEFT" styleClass="title-bar" spacing="4">
        <padding>
            <Insets top="4" right="4" bottom="0" left="16"/>
        </padding>

        <Label text="BidBlitz" styleClass="title-bar-label"/>

        <Region HBox.hgrow="ALWAYS"/>


        <!--  first row: window bar row -->
        <HBox spacing="6">
            <Button onAction="#handleMinimize" styleClass="window-button">
                <graphic>
                    <StackPane scaleX="0.6" scaleY="0.6">
                        <SVGPath content="M5 12h14" styleClass="window-icon"/>
                    </StackPane>
                </graphic>
            </Button>

            <Button onAction="#handleMaximize" styleClass="window-button">
                <graphic>
                    <StackPane>
                        <Group fx:id="maximizeGraphic" scaleX="0.6" scaleY="0.6">
                            <children>
                                <SVGPath fx:id="maximizePath1" content="M15 3h6v6" styleClass="window-icon"/>
                                <SVGPath fx:id="maximizePath2" content="m21 3-7 7" styleClass="window-icon"/>
                                <SVGPath fx:id="maximizePath3" content="m3 21 7-7" styleClass="window-icon"/>
                                <SVGPath fx:id="maximizePath4" content="M9 21H3v-6" styleClass="window-icon"/>
                            </children>
                        </Group>
                    </StackPane>
                </graphic>
            </Button>

            <Button onAction="#handleClose" styleClass="window-button-close">
                <graphic>
                    <StackPane scaleX="0.6" scaleY="0.6">
                        <children>
                            <SVGPath content="M18 6 6 18" styleClass="window-icon"/>
                            <SVGPath content="m6 6 12 12" styleClass="window-icon"/>
                        </children>
                    </StackPane>
                </graphic>
            </Button>
        </HBox>
    </HBox>


    <!--  second row: tools row -->
    <HBox alignment="CENTER" spacing="10" styleClass="app-toolbar">
        <padding>
            <Insets top="0" right="4" bottom="4" left="16"/>
        </padding>

        <HBox alignment="CENTER_LEFT">
            <StackPane scaleX="1.2" scaleY="1.2">
                <SVGPath content="M13 2L3 14h9l-1 8 10-12h-9l1-8z" styleClass="logo-icon"/>
            </StackPane>
        </HBox>

        <Region HBox.hgrow="ALWAYS"/>

        <HBox alignment="CENTER_LEFT" styleClass="search-box">
            <SVGPath content="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"
                     styleClass="search-icon"/>
            <TextField promptText="Search (Ctrl+Alt+E)" styleClass="search-field" focusTraversable="false"/>
        </HBox>

        <Region HBox.hgrow="ALWAYS"/>

        <HBox alignment="CENTER_RIGHT" spacing="10">
            <Button styleClass="tool-button">
                <graphic>
                    <SVGPath content="M2 9.5a5.5 5.5 0 0 1 9.591-3.676.56.56 0 0 0 .818 0A5.49 5.49 0 0 1 22 9.5c0 2.29-1.5 4-3 5.5l-5.492 5.313a2 2 0 0 1-3 .019L5 15c-1.5-1.5-3-3.2-3-5.5" styleClass="tool-icon"/>
                </graphic>
            </Button>

            <Button styleClass="tool-button">
                <graphic>
                    <SVGPath content="M10.268 21a2 2 0 0 0 3.464 0 M11.68 2.009A6 6 0 0 0 6 8c0 4.499-1.411 5.956-2.738 7.326A1 1 0 0 0 4 17h16a1 1 0 0 0 .74-1.673c-.824-.85-1.678-1.731-2.21-3.348 M15 5 a3 3 0 1 0 6 0 a3 3 0 1 0 -6 0" styleClass="tool-icon"/>
                </graphic>
            </Button>

            <MenuButton fx:id="avatarMenu" styleClass="avatar-menu">
                <graphic>
                    <SVGPath content="M17.925 20.056a6 6 0 0 0-11.851.001 M8 11 a4 4 0 1 0 8 0 a4 4 0 1 0 -8 0 M2 12 a10 10 0 1 0 20 0 a10 10 0 1 0 -20 0" styleClass="tool-icon"/>
                </graphic>
                <items>
                    <MenuItem text="My Profile"/>
                    <MenuItem text="Settings"/>
                    <MenuItem text="Sign out"/>
                </items>
            </MenuButton>
        </HBox>
    </HBox>
</VBox>