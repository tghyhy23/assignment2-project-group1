<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>

<ScrollPane fx:id="exploreScrollPane"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.group01.asm2.controllers.ExploreController"
            fitToWidth="true"
            styleClass="explore-scroll"
            stylesheets="@../styles/views/explore.css"
            hbarPolicy="NEVER"
            vbarPolicy="AS_NEEDED">

    <VBox fx:id="exploreRoot" styleClass="explore-root" spacing="30">

        <padding>
            <Insets top="30" right="40" bottom="30" left="40"/>
        </padding>

        <StackPane styleClass="welcome-banner" minHeight="700">
            <VBox alignment="CENTER_LEFT" spacing="8">
                <padding>
                    <Insets top="40" right="40" bottom="40" left="40"/>
                </padding>
                <Label text="WELCOME TO BIDBLITZ" styleClass="banner-title"/>
                <Label text="Discover exclusive items, join the auction, and make them yours today!" styleClass="banner-subtitle" wrapText="true"/>
            </VBox>
        </StackPane>

        <fx:include source="components/feature_explore.fxml" />

        <fx:include source="components/categories_explore.fxml" />

        <fx:include source="components/all_auctions.fxml" />

    </VBox>
</ScrollPane>