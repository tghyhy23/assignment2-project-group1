<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.group01.asm2.controllers.SignupController"
            prefWidth="1100"
            prefHeight="720"
            stylesheets="@../styles/auth.css"
            styleClass="auth-root">

    <children>
        <HBox AnchorPane.topAnchor="0"
              AnchorPane.bottomAnchor="0"
              AnchorPane.leftAnchor="0"
              AnchorPane.rightAnchor="0">

            <!-- LEFT BRAND SECTION -->
            <VBox styleClass="auth-left-panel"
                  prefWidth="500"
                  alignment="CENTER"
                  spacing="22">

                <Label text="BidBlitz" styleClass="brand-title"/>

                <Label text="Join the auction experience built for modern bidders."
                       styleClass="brand-subtitle"
                       wrapText="true"
                       maxWidth="340"/>

            </VBox>

            <!-- RIGHT SIGNUP SECTION -->
            <VBox styleClass="auth-right-panel"
                  alignment="CENTER">

                <VBox styleClass="auth-card"
                      spacing="10"
                      maxWidth="450">

                    <VBox spacing="6">
                        <Label text="Create Account" styleClass="auth-title"/>
                        <Label text="Sign up to start bidding on BidBlitz"
                               styleClass="auth-subtitle"/>
                    </VBox>

                    <VBox spacing="4">
                        <Label text="Full Name" styleClass="input-label"/>
                        <TextField fx:id="fullNameField"
                                   promptText="Enter your full name"
                                   styleClass="auth-input"/>
                    </VBox>

                    <VBox spacing="4">
                        <Label text="Email Address" styleClass="input-label"/>
                        <TextField fx:id="emailField"
                                   promptText="Enter your email"
                                   styleClass="auth-input"/>
                    </VBox>

                    <VBox spacing="4">
                        <Label text="Date of Birth" styleClass="input-label"/>
                        <DatePicker fx:id="dateOfBirthPicker"
                                    promptText="Select your date of birth"
                                    maxWidth="Infinity"
                                    styleClass="auth-date-picker"/>
                    </VBox>

                    <VBox spacing="4">
                        <Label text="Password" styleClass="input-label"/>
                        <PasswordField fx:id="passwordField"
                                       promptText="Create a password"
                                       styleClass="auth-input"/>
                    </VBox>

                    <VBox spacing="4">
                        <Label text="Confirm Password" styleClass="input-label"/>
                        <PasswordField fx:id="confirmPasswordField"
                                       promptText="Confirm your password"
                                       styleClass="auth-input"/>
                    </VBox>

                    <VBox spacing="4">
                        <Label text="Role" styleClass="input-label"/>
                        <ComboBox fx:id="roleComboBox"
                                  promptText="Select role"
                                  maxWidth="Infinity"
                                  styleClass="auth-combo"/>
                    </VBox>

                    <Label fx:id="messageLabel"
                           text=""
                           styleClass="error-message"
                           wrapText="true"/>

                    <Button text="Create Account"
                            onAction="#handleSignup"
                            maxWidth="Infinity"
                            styleClass="primary-button"/>

                    <HBox alignment="CENTER" spacing="5">
                        <Label text="Already have an account?"
                               styleClass="bottom-text"/>
                        <Hyperlink text="Login"
                                   onAction="#goToLogin"
                                   styleClass="auth-link"/>
                    </HBox>

                </VBox>
            </VBox>

        </HBox>
    </children>
</AnchorPane>