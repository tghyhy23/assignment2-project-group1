<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.group01.asm2.controllers.AuctionsController"
      spacing="18"
      stylesheets="@../styles/views/auctions.css"
      styleClass="auctions-root">

    <padding>
        <Insets top="30" right="40" bottom="30" left="40"/>
    </padding>

    <HBox spacing="16" alignment="CENTER_LEFT">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Won Auctions" styleClass="page-title"/>
            <Label text="View your won auctions, payment records, and purchase summary."
                   styleClass="page-subtitle"/>
        </VBox>

        <Region HBox.hgrow="ALWAYS"/>

        <Button fx:id="exportPurchaseSummaryButton"
                text="Export Purchase Summary"
                styleClass="primary-action-button"
                onAction="#handleExportPurchaseSummary"/>
    </HBox>

    <HBox spacing="14">
        <VBox styleClass="summary-card" HBox.hgrow="ALWAYS">
            <Label text="Won Auctions" styleClass="summary-label"/>
            <Label fx:id="totalWonLabel" text="0" styleClass="summary-value"/>
        </VBox>

        <VBox styleClass="summary-card" HBox.hgrow="ALWAYS">
            <Label text="Total Spent" styleClass="summary-label"/>
            <Label fx:id="totalSpentLabel" text="\$0.00" styleClass="summary-value"/>
        </VBox>

        <VBox styleClass="summary-card" HBox.hgrow="ALWAYS">
            <Label text="Completed Payments" styleClass="summary-label"/>
            <Label fx:id="completedPaymentsLabel" text="0" styleClass="summary-value"/>
        </VBox>
    </HBox>

    <VBox styleClass="content-card" VBox.vgrow="ALWAYS">
        <TableView fx:id="wonAuctionsTable"
                   styleClass="modern-table"
                   VBox.vgrow="ALWAYS">

            <columns>
                <TableColumn fx:id="wonDateColumn"
                             text="Won Date"
                             prefWidth="115"/>

                <TableColumn fx:id="itemColumn"
                             text="Item"
                             prefWidth="190"/>

                <TableColumn fx:id="sellerColumn"
                             text="Seller"
                             prefWidth="110"/>

                <TableColumn fx:id="categoryColumn"
                             text="Category"
                             prefWidth="110"/>

                <TableColumn fx:id="finalPriceColumn"
                             text="Final Price"
                             prefWidth="110"/>

                <TableColumn fx:id="paymentAmountColumn"
                             text="Paid Amount"
                             prefWidth="115"/>

                <TableColumn fx:id="paymentStatusColumn"
                             text="Payment"
                             prefWidth="125"/>

                <TableColumn fx:id="paymentDateColumn"
                             text="Payment Date"
                             prefWidth="125"/>

                <TableColumn fx:id="wonAuctionStatusColumn"
                             text="Auction"
                             prefWidth="100"/>

                <TableColumn fx:id="actionColumn"
                             text="Action"
                             prefWidth="80"/>
            </columns>
        </TableView>
    </VBox>

</VBox>