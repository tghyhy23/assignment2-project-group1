<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<?import javafx.geometry.Insets?>
<StackPane xmlns="http://javafx.com/javafx"
           fx:id="allAuctionsRoot"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.group01.asm2.controllers.AuctionsController"
           stylesheets="@../../styles/components/all_auctions.css">

    <!-- Main content -->
    <VBox styleClass="all-auctions-section"
          spacing="10">

        <HBox alignment="CENTER_LEFT">
            <Label fx:id="browseTitleLabel"
                   text="BROWSE AUCTIONS"
                   styleClass="section-title"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button fx:id="filterButton"
                    text="Filter"
                    styleClass="filter-button"
                    onAction="#handleOpenFilterForm">

                <HBox.margin>
                    <Insets right="50"/>
                </HBox.margin>

            </Button>
        </HBox>

        <FlowPane fx:id="allAuctionsContainer"
                  hgap="20"
                  vgap="16"
                  prefWrapLength="1040"
                  maxWidth="1040"
                  styleClass="auction-grid"/>

        <HBox fx:id="paginationBox"
              spacing="10"
              alignment="CENTER"
              styleClass="pagination-box">

            <Button fx:id="prevPageButton"
                    text="Prev"
                    styleClass="pagination-button"
                    onAction="#handlePrevPage"/>

            <Label fx:id="pageInfoLabel"
                   text="Page 1 / 1"
                   styleClass="pagination-label"/>

            <Button fx:id="nextPageButton"
                    text="Next"
                    styleClass="pagination-button"
                    onAction="#handleNextPage"/>
        </HBox>

    </VBox>

    <!-- Filter Modal -->
    <StackPane fx:id="filterModalOverlay"
               visible="false"
               managed="false"
               styleClass="filter-modal-overlay">

        <VBox styleClass="filter-modal-card"
              maxWidth="900"
              spacing="12">

            <HBox alignment="CENTER_LEFT">
                <VBox spacing="4">
                    <Label text="Filter Auctions"
                           styleClass="filter-modal-title"/>

                    <Label text="Choose options to narrow down auction results."
                           styleClass="filter-modal-subtitle"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <Button text="X"
                        styleClass="modal-close-button"
                        onAction="#handleCloseFilterForm"/>
            </HBox>

            <GridPane hgap="20"
                      vgap="10">

                <Label text="Category"
                       styleClass="form-label"
                       GridPane.rowIndex="0"
                       GridPane.columnIndex="0"/>

                <ComboBox fx:id="categoryFilterBox"
                          promptText="Select category"
                          styleClass="form-combo"
                          visibleRowCount="5"
                          GridPane.rowIndex="1"
                          GridPane.columnIndex="0"/>

                <Label text="Condition"
                       styleClass="form-label"
                       GridPane.rowIndex="0"
                       GridPane.columnIndex="1"/>

                <ComboBox fx:id="conditionFilterBox"
                          promptText="Select condition"
                          styleClass="form-combo"
                          GridPane.rowIndex="1"
                          GridPane.columnIndex="1"/>

                <Label text="Min Price"
                       styleClass="form-label"
                       GridPane.rowIndex="2"
                       GridPane.columnIndex="0"/>

                <TextField fx:id="minPriceField"
                           promptText="Minimum price"
                           styleClass="form-input"
                           GridPane.rowIndex="3"
                           GridPane.columnIndex="0"/>

                <Label text="Max Price"
                       styleClass="form-label"
                       GridPane.rowIndex="2"
                       GridPane.columnIndex="1"/>

                <TextField fx:id="maxPriceField"
                           promptText="Maximum price"
                           styleClass="form-input"
                           GridPane.rowIndex="3"
                           GridPane.columnIndex="1"/>

                <CheckBox fx:id="endingSoonCheck"
                          text="Ending within 24 hours"
                          styleClass="form-checkbox"
                          GridPane.rowIndex="4"
                          GridPane.columnIndex="0"/>
            </GridPane>

            <HBox alignment="CENTER_RIGHT"
                  spacing="12">

                <Button text="Reset"
                        styleClass="secondary-button"
                        onAction="#handleResetFilters"/>

                <Button text="Cancel"
                        styleClass="secondary-button"
                        onAction="#handleCloseFilterForm"/>

                <Button text="Apply Filters"
                        styleClass="primary-button"
                        onAction="#handleApplyFilters"/>
            </HBox>

        </VBox>
    </StackPane>

</StackPane>