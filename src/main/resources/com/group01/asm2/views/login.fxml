<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.group01.asm2.controllers.LoginController"
            stylesheets="@../styles/views/auth.css"
            styleClass="auth-root">

    <children>
        <HBox fx:id="authContainer"
              AnchorPane.topAnchor="0"
              AnchorPane.bottomAnchor="0"
              AnchorPane.leftAnchor="0"
              AnchorPane.rightAnchor="0">

            <!-- LEFT BRAND SECTION -->
            <VBox fx:id="leftPanel"
                  styleClass="auth-left-panel"
                  alignment="CENTER"
                  spacing="22"
                  HBox.hgrow="ALWAYS">

                <Label text="BidBlitz" styleClass="brand-title"/>

                <Label text="Auction smarter. Bid faster. Win better."
                       styleClass="brand-subtitle"
                       wrapText="true"/>
            </VBox>

            <!-- RIGHT LOGIN SECTION -->
            <VBox fx:id="rightPanel"
                  styleClass="auth-right-panel"
                  alignment="CENTER"
                  HBox.hgrow="ALWAYS">

                <VBox fx:id="authCard"
                      styleClass="auth-card"
                      spacing="10">

                    <VBox spacing="6">
                        <Label text="Welcome Back" styleClass="auth-title"/>
                        <Label text="Login to continue using BidBlitz"
                               styleClass="auth-subtitle"/>
                    </VBox>

                    <VBox spacing="8">
                        <Label text="Username" styleClass="input-label"/>
                        <TextField fx:id="usernameField"
                                   id="usernameField"
                                   promptText="Enter your username"
                                   styleClass="auth-input"/>
                    </VBox>

                    <VBox spacing="8">
                        <Label text="Password" styleClass="input-label"/>
                        <PasswordField fx:id="passwordField"
                                       id="passwordField"
                                       promptText="Enter your password"
                                       styleClass="auth-input"/>
                    </VBox>

                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <CheckBox fx:id="rememberMeCheckBox"
                                  text="Remember me"
                                  styleClass="auth-checkbox"/>

                        <Region HBox.hgrow="ALWAYS"/>

                        <Hyperlink text="Forgot password?"
                                   styleClass="auth-link"/>
                    </HBox>

                    <Label fx:id="messageLabel"
                           id="messageLabel"
                           text=""
                           styleClass="error-message"
                           wrapText="true"/>

<!--                    <Button text="Login"-->
<!--                            onAction="#handleLogin"-->
<!--                            maxWidth="Infinity"-->
<!--                            styleClass="primary-button"/>-->
                    <Button
                            fx:id="loginButton"
                            id="loginButton"
                            text="Login"
                            userData="rate=LOGIN;identity=usernameField;message=messageLabel"
                            maxWidth="Infinity"
                            styleClass="primary-button"/>

                    <HBox alignment="CENTER" spacing="5">
                        <Label text="Don't have an account?"
                               styleClass="bottom-text"/>
                        <Hyperlink
                                    fx:id="signupLink"
                                    text="Sign up"
                                    styleClass="auth-link"/>
                    </HBox>

                </VBox>
            </VBox>

        </HBox>
    </children>
</AnchorPane>