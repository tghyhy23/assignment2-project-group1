<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.*?>

<StackPane fx:id="rootPane" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.group01.asm2.controllers.SystemLogsController"
           stylesheets="@../../styles/system-admin/system-users.css">

    <ScrollPane fx:id="mainScrollPane" fitToWidth="true" styleClass="system-root">
        <VBox spacing="20" fillWidth="true">
            <padding><Insets top="30" right="40" bottom="30" left="40"/></padding>

            <VBox spacing="5">
                <Label text="System Logs" styleClass="dashboard-title"/>
                <Label text="Complete system-wide activity log, covering all operations by users and admins." styleClass="dashboard-subtitle"/>
            </VBox>

            <HBox spacing="15" alignment="CENTER_LEFT">
                <TextField fx:id="searchField" promptText="Search username or details..." styleClass="filter-field" prefWidth="300"/>
                <ComboBox fx:id="roleFilterCombo" promptText="Role" styleClass="filter-field" prefWidth="150"/>
                <ComboBox fx:id="actionFilterCombo" promptText="Action" styleClass="filter-field" prefWidth="150"/>
            </HBox>

            <TableView fx:id="logsTable" VBox.vgrow="ALWAYS" minHeight="550">
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                <columns>
                    <TableColumn text="Timestamp" prefWidth="150" minWidth="130" maxWidth="180">
                        <cellValueFactory><PropertyValueFactory property="timestamp"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn text="Role" prefWidth="120" minWidth="100" maxWidth="150">
                        <cellValueFactory><PropertyValueFactory property="role"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn text="Username" prefWidth="120" minWidth="100">
                        <cellValueFactory><PropertyValueFactory property="username"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn text="Action" prefWidth="100" minWidth="80" maxWidth="120">
                        <cellValueFactory><PropertyValueFactory property="action"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn text="Target Entity" prefWidth="120" minWidth="100" maxWidth="150">
                        <cellValueFactory><PropertyValueFactory property="entity"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn text="Log Details" prefWidth="300" minWidth="250">
                        <cellValueFactory><PropertyValueFactory property="details"/></cellValueFactory>
                    </TableColumn>
                </columns>
            </TableView>
        </VBox>
    </ScrollPane>
</StackPane>