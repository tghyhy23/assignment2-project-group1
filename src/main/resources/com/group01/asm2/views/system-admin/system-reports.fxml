<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.*?>

<ScrollPane fx:id="mainScrollPane" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.group01.asm2.controllers.SystemReportsController"
            stylesheets="@../../styles/system-admin/system-users.css"
            styleClass="system-root" fitToWidth="true" prefHeight="750.0" prefWidth="1050.0">

    <VBox spacing="20" fillWidth="true">
        <padding><Insets top="30" right="40" bottom="30" left="40"/></padding>

        <VBox spacing="5">
            <Label text="System Reports &amp; Analytics" styleClass="dashboard-title"/>
            <Label text="Comprehensive statistics on users, auctions, items, bids, and financial payments." styleClass="dashboard-subtitle"/>
        </VBox>

        <HBox spacing="15" alignment="CENTER_LEFT">
            <VBox spacing="5">
                <Label text="Report Entity" styleClass="filter-label"/>
                <ComboBox fx:id="reportTypeCombo" prefWidth="200" styleClass="filter-field"/>
            </VBox>
            <VBox spacing="5">
                <Label text="Start Date" styleClass="filter-label"/>
                <DatePicker fx:id="startDatePicker" styleClass="filter-field" prefWidth="160"/>
            </VBox>
            <VBox spacing="5">
                <Label text="End Date" styleClass="filter-label"/>
                <DatePicker fx:id="endDatePicker" styleClass="filter-field" prefWidth="160"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="⬇ Download CSV" onAction="#handleDownload" styleClass="btn-add-primary"/>
        </HBox>

        <HBox spacing="15">
            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                <Label text="Total System Revenue" styleClass="stat-title"/>
                <Label fx:id="totalRevenueLabel" text="\$0.00" styleClass="stat-value-green"/>
            </VBox>
            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                <Label text="Total Registered Users" styleClass="stat-title"/>
                <Label fx:id="totalUsersLabel" text="0" styleClass="stat-value-blue"/>
            </VBox>
            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                <Label text="Active Auctions" styleClass="stat-title"/>
                <Label fx:id="activeAuctionsLabel" text="0" styleClass="stat-value-purple"/>
            </VBox>
        </HBox>

        <HBox spacing="20" prefHeight="320">
            <VBox styleClass="modal-box" HBox.hgrow="ALWAYS" prefWidth="600">
                <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                <Label text="Growth Trend" styleClass="section-title"/>
                <LineChart fx:id="trendChart" legendVisible="false" VBox.vgrow="ALWAYS">
                    <xAxis><CategoryAxis label="Timeline"/></xAxis>
                    <yAxis><NumberAxis label="Count / Volume"/></yAxis>
                </LineChart>
            </VBox>

            <VBox styleClass="modal-box" HBox.hgrow="ALWAYS" prefWidth="400">
                <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                <Label text="Distribution" styleClass="section-title"/>
                <PieChart fx:id="distributionChart" VBox.vgrow="ALWAYS" labelsVisible="true"/>
            </VBox>
        </HBox>

        <VBox spacing="10" VBox.vgrow="ALWAYS">
            <Label text="Detailed Data Table" styleClass="section-title"/>
            <TableView fx:id="reportTable" VBox.vgrow="ALWAYS" minHeight="300">
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
            </TableView>
        </VBox>

    </VBox>
</ScrollPane>