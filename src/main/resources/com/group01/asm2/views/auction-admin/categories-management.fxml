<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.cell.PropertyValueFactory?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.group01.asm2.controllers.AdminCategoriesController"
           stylesheets="@../../styles/auction-admin/admin-categories.css"
           styleClass="admin-categories-root"
           prefHeight="600.0" prefWidth="900.0">

    <VBox spacing="18" fillWidth="true">
        <padding>
            <Insets top="30" right="40" bottom="30" left="40"/>
        </padding>

        <VBox spacing="4">
            <Label text="Categories Management" styleClass="dashboard-title"/>
            <Label text="Create, update, and delete item categories." styleClass="dashboard-subtitle"/>
        </VBox>

        <HBox spacing="10" alignment="CENTER_LEFT">
            <TextField fx:id="searchField" promptText="Search category name..." styleClass="filter-field" prefWidth="300"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="+ Add Category" onAction="#openAddModal" styleClass="action-btn"/>
        </HBox>

        <TableView fx:id="categoriesTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn text="ID" prefWidth="80" minWidth="80">
                    <cellValueFactory><PropertyValueFactory property="id"/></cellValueFactory>
                </TableColumn>
                <TableColumn text="Category Name" prefWidth="250" minWidth="200">
                    <cellValueFactory><PropertyValueFactory property="name"/></cellValueFactory>
                </TableColumn>
                <TableColumn text="Description" prefWidth="350" minWidth="250">
                    <cellValueFactory><PropertyValueFactory property="description"/></cellValueFactory>
                </TableColumn>
                <TableColumn text="Commission (%)" prefWidth="120" minWidth="100">
                    <cellValueFactory><PropertyValueFactory property="commissionRate"/></cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="actionCol" text="Actions" prefWidth="180" minWidth="160"/>
            </columns>
        </TableView>
    </VBox>


    <StackPane fx:id="modalOverlay" visible="false" styleClass="modal-overlay">

        <VBox styleClass="modal-box" maxWidth="500" maxHeight="450" spacing="16">

            <HBox alignment="CENTER_LEFT">
                <Label fx:id="modalTitle" text="Add Category" styleClass="modal-title"/>
                <Region HBox.hgrow="ALWAYS"/> <Button text="✕" onAction="#closeModal" styleClass="btn-close-modal"/>
            </HBox>

            <VBox spacing="6">
                <Label text="Category Name" styleClass="modal-label"/>
                <TextField fx:id="nameInput" promptText="E.g. Electronics" styleClass="filter-field"/>
            </VBox>

            <VBox spacing="6" VBox.vgrow="ALWAYS">
                <Label text="Description" styleClass="modal-label"/>
                <TextArea fx:id="descInput" promptText="Enter description..." VBox.vgrow="ALWAYS" wrapText="true"/>
            </VBox>

            <VBox spacing="6">
                <Label text="Commission Rate (%)" styleClass="modal-label"/>
                <TextField fx:id="commInput" promptText="E.g. 5.5" styleClass="filter-field"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <HBox spacing="12" alignment="CENTER_RIGHT">
                <Button text="Cancel" onAction="#closeModal" styleClass="btn-cancel"/>
                <Button text="Save Category" onAction="#saveCategory" styleClass="btn-save"/>
            </HBox>
        </VBox>

    </StackPane>

</StackPane>