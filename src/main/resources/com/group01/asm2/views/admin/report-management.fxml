<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.cell.PropertyValueFactory?>

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.group01.asm2.controllers.AdminReportController"
            fx:id="mainScrollPane"
            stylesheets="@../../styles/admin/admin-report.css"
            styleClass="admin-report-root"
            fitToWidth="true"
            prefHeight="700.0" prefWidth="1000.0">

    <VBox spacing="20" fillWidth="true">
        <padding>
            <Insets top="30" right="40" bottom="30" left="40"/>
        </padding>

        <VBox spacing="4">
            <Label text="Reports &amp; Analytics" styleClass="dashboard-title"/>
            <Label text="Generate and download auction-level reports and financial summaries." styleClass="dashboard-subtitle"/>
        </VBox>

        <HBox spacing="15" alignment="CENTER_LEFT" styleClass="toolbar-box">
            <VBox spacing="4">
                <Label text="Report Type" styleClass="filter-label"/>
                <ComboBox fx:id="reportTypeCombo" prefWidth="200" styleClass="filter-field"/>
            </VBox>

            <VBox spacing="4">
                <Label text="Start Date" styleClass="filter-label"/>
                <DatePicker fx:id="startDatePicker" styleClass="filter-field" prefWidth="150"/>
            </VBox>

            <VBox spacing="4">
                <Label text="End Date" styleClass="filter-label"/>
                <DatePicker fx:id="endDatePicker" styleClass="filter-field" prefWidth="150"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="⬇ Download Report (CSV)" onAction="#handleDownload" styleClass="btn-download"/>
        </HBox>

        <HBox spacing="15">
            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                <Label text="Total Revenue" styleClass="stat-title"/>
                <Label fx:id="totalRevenueLabel" text="\$0.00" styleClass="stat-value-green"/>
            </VBox>
            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                <Label text="Total Commission" styleClass="stat-title"/>
                <Label fx:id="totalCommissionLabel" text="\$0.00" styleClass="stat-value-blue"/>
            </VBox>
            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                <Label text="Overall Success Rate" styleClass="stat-title"/>
                <Label fx:id="successRateLabel" text="0%" styleClass="stat-value-purple"/>
            </VBox>
        </HBox>

        <HBox spacing="20" prefHeight="300">
            <VBox styleClass="chart-container" HBox.hgrow="ALWAYS" prefWidth="500">
                <Label text="Revenue per Category" styleClass="section-title"/>
                <BarChart fx:id="revenueChart" legendVisible="false" VBox.vgrow="ALWAYS">
                    <xAxis><CategoryAxis label="Category"/></xAxis>
                    <yAxis><NumberAxis label="Amount ($)"/></yAxis>
                </BarChart>
            </VBox>

            <VBox styleClass="chart-container" HBox.hgrow="ALWAYS" prefWidth="400">
                <Label text="Auction Success Rates" styleClass="section-title"/>
                <PieChart fx:id="successPieChart" VBox.vgrow="ALWAYS" labelsVisible="true"/>
            </VBox>
        </HBox>

        <VBox spacing="10" VBox.vgrow="ALWAYS">
            <Label text="Detailed Report Data" styleClass="section-title"/>

            <TableView fx:id="reportTable" VBox.vgrow="ALWAYS" minWidth="900" prefHeight="250">
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
                <columns>
                    <TableColumn text="Auction ID" prefWidth="100" minWidth="80" maxWidth="120">
                        <cellValueFactory><PropertyValueFactory property="auctionId"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn text="Category" prefWidth="150" minWidth="120">
                        <cellValueFactory><PropertyValueFactory property="category"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn text="Total Bids" prefWidth="100" minWidth="80">
                        <cellValueFactory><PropertyValueFactory property="totalBids"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn text="Final Price ($)" prefWidth="150" minWidth="120">
                        <cellValueFactory><PropertyValueFactory property="finalPrice"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn text="Commission ($)" prefWidth="150" minWidth="120">
                        <cellValueFactory><PropertyValueFactory property="commission"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn text="Status" prefWidth="120" minWidth="100">
                        <cellValueFactory><PropertyValueFactory property="status"/></cellValueFactory>
                    </TableColumn>
                </columns>
            </TableView>
        </VBox>

    </VBox>
</ScrollPane>