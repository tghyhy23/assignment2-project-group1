<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.cell.PropertyValueFactory?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.group01.asm2.controllers.AdminAuctionController"
            stylesheets="@../../styles/admin/admin-auction.css"
            styleClass="admin-auction-root">

    <VBox spacing="18" fillWidth="true" AnchorPane.topAnchor="0.0"
          AnchorPane.rightAnchor="0.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0">
        <padding>
            <Insets top="30" right="40" bottom="30" left="40"/>
        </padding>

        <VBox spacing="4">
            <Label text="Auction Management" styleClass="auction-title"/>
            <Label text="Manage auction lifecycle, processing, and financial transactions."
                   styleClass="auction-subtitle"/>
        </VBox>

        <HBox spacing="6" styleClass="auction-tabs">
            <Button fx:id="configTab" text="Auction Config" onAction="#showConfig" styleClass="auction-tab-button"/>
            <Button fx:id="dueTab" text="Due Processing" onAction="#showDue" styleClass="auction-tab-button"/>
            <Button fx:id="transactionsTab" text="Transactions" onAction="#showTransactions" styleClass="auction-tab-button"/>
        </HBox>
        <ScrollPane fx:id="mainScrollPane" fitToWidth="true" fitToHeight="true" VBox.vgrow="ALWAYS" styleClass="main-scroll-pane">
        <StackPane fx:id="contentArea" VBox.vgrow="ALWAYS" styleClass="auction-content-area">

            <VBox fx:id="configView" spacing="12" visible="false">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <TextField promptText="Search Auction or Item ID..." styleClass="search-field" prefWidth="250"/>
                    <ComboBox fx:id="filterStatusCombo" promptText="Filter Status" styleClass="filter-field"/>
                </HBox>

                <TableView fx:id="configTable" VBox.vgrow="ALWAYS" minWidth="950">

                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>

                    <columns>
                        <TableColumn text="Auction ID" prefWidth="100" minWidth="80" maxWidth="120">
                            <cellValueFactory><PropertyValueFactory property="id"/></cellValueFactory>
                        </TableColumn>

                        <TableColumn text="Item ID" prefWidth="100" minWidth="80" maxWidth="120">
                            <cellValueFactory><PropertyValueFactory property="itemId"/></cellValueFactory>
                        </TableColumn>

                        <TableColumn text="Start Date" prefWidth="200" minWidth="150">
                            <cellValueFactory><PropertyValueFactory property="startDateTime"/></cellValueFactory>
                        </TableColumn>

                        <TableColumn text="End Date" prefWidth="200" minWidth="150">
                            <cellValueFactory><PropertyValueFactory property="endDateTime"/></cellValueFactory>
                        </TableColumn>

                        <TableColumn text="Status" prefWidth="150" minWidth="100">
                            <cellValueFactory><PropertyValueFactory property="status"/></cellValueFactory>
                        </TableColumn>

                        <TableColumn fx:id="configActionCol" text="Actions" prefWidth="150" minWidth="150" maxWidth="150"/>
                    </columns>
                </TableView>
            </VBox>


            <VBox fx:id="dueView" spacing="12" visible="false">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Auctions Ended &amp; Pending Resolution" styleClass="section-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Refresh List" styleClass="action-btn"/>
                </HBox>

                <TableView fx:id="dueTable" VBox.vgrow="ALWAYS" minWidth="850">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                    <columns>
                        <TableColumn text="Auction ID" prefWidth="120" minWidth="80" maxWidth="120">
                            <cellValueFactory><PropertyValueFactory property="id"/></cellValueFactory>
                        </TableColumn>
                        <TableColumn text="Item ID" prefWidth="100" minWidth="80" maxWidth="120">
                            <cellValueFactory><PropertyValueFactory property="itemId"/></cellValueFactory>
                        </TableColumn>
                        <TableColumn text="End Date" prefWidth="250" minWidth="180">
                            <cellValueFactory><PropertyValueFactory property="endDateTime"/></cellValueFactory>
                        </TableColumn>
                        <TableColumn text="Highest Bid ID" prefWidth="150" minWidth="120">
                            <cellValueFactory><PropertyValueFactory property="currentHighestBidId"/></cellValueFactory>
                        </TableColumn>
                        <TableColumn fx:id="dueActionCol" text="Process Action" prefWidth="150" minWidth="150" maxWidth="150"/>
                    </columns>
                </TableView>
            </VBox>

            <VBox fx:id="transactionsView" spacing="20" visible="false" VBox.vgrow="ALWAYS">

                <VBox spacing="8" VBox.vgrow="ALWAYS">
                    <Label text="Pending Top-up Requests" styleClass="section-title"/>

                    <TableView fx:id="topUpTable" VBox.vgrow="ALWAYS" minWidth="800">
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                        <columns>
                            <TableColumn text="User ID" prefWidth="120" minWidth="80" maxWidth="150">
                                <cellValueFactory><PropertyValueFactory property="userId"/></cellValueFactory>
                            </TableColumn>
                            <TableColumn text="Amount" prefWidth="200" minWidth="150">
                                <cellValueFactory><PropertyValueFactory property="amount"/></cellValueFactory>
                            </TableColumn>
                            <TableColumn text="Date Requested" prefWidth="250" minWidth="180">
                                <cellValueFactory><PropertyValueFactory property="createdAt"/></cellValueFactory>
                            </TableColumn>
                            <TableColumn fx:id="topUpActionCol" text="Actions" prefWidth="180" minWidth="180" maxWidth="180"/>
                        </columns>
                    </TableView>
                </VBox>

                <VBox spacing="8" VBox.vgrow="ALWAYS">
                    <Label text="Auction Payment Status (SOLD Auctions)" styleClass="section-title"/>

                    <TableView fx:id="paymentTable" VBox.vgrow="ALWAYS" minWidth="750">
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                        <columns>
                            <TableColumn text="Auction ID" prefWidth="120" minWidth="80" maxWidth="150">
                                <cellValueFactory><PropertyValueFactory property="id"/></cellValueFactory>
                            </TableColumn>
                            <TableColumn text="Winner ID" prefWidth="120" minWidth="80" maxWidth="150">
                                <cellValueFactory><PropertyValueFactory property="winnerId"/></cellValueFactory>
                            </TableColumn>
                            <TableColumn text="Final Price" prefWidth="250" minWidth="150">
                                <cellValueFactory><PropertyValueFactory property="finalSalePrice"/></cellValueFactory>
                            </TableColumn>
                            <TableColumn fx:id="paymentActionCol" text="Update Payment" prefWidth="150" minWidth="150" maxWidth="150"/>
                        </columns>
                    </TableView>
                </VBox>

            </VBox>
        </StackPane>
        </ScrollPane>
    </VBox>
</AnchorPane>