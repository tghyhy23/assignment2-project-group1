<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.group01.asm2.controllers.BidsHistoryController"
      spacing="16"
      stylesheets="@../styles/views/bids_history.css"
      styleClass="bids-root">

    <padding>
        <Insets top="24" right="24" bottom="24" left="24"/>
    </padding>

    <Label text="Bid History" styleClass="page-title"/>
    <Label text="View and track your current and past bids." styleClass="page-subtitle"/>

    <VBox styleClass="content-card" VBox.vgrow="ALWAYS">
        <TableView fx:id="bidsTable" styleClass="modern-table">
            <columns>
                <TableColumn fx:id="bidItemNameColumn" text="Item Name" prefWidth="200"/>
                <TableColumn fx:id="bidMyAmountColumn" text="My Bid" prefWidth="120"/>
                <TableColumn fx:id="bidHighestAmountColumn" text="Current Highest" prefWidth="120"/>
                <TableColumn fx:id="bidStatusColumn" text="Status" prefWidth="100"/>
                <TableColumn fx:id="bidDateColumn" text="Date" prefWidth="120"/>
            </columns>
        </TableView>
    </VBox>

</VBox>