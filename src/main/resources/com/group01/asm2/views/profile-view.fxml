<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.group01.asm2.controllers.ProfileController"
            stylesheets="@../styles/profile.css"
            styleClass="profile-root">

    <center>
        <ScrollPane fitToWidth="true"
                    hbarPolicy="NEVER"
                    vbarPolicy="AS_NEEDED"
                    styleClass="profile-scroll">

            <VBox spacing="24" styleClass="profile-container">

                <!-- =========================
                     Top Header Row
                ========================== -->
                <HBox spacing="16" styleClass="top-row">
                    <VBox spacing="4">
                        <Label text="Profile" styleClass="page-title"/>
                        <Label text="Manage your BidBlitz account, auctions, transactions and notifications."
                               styleClass="page-subtitle"/>
                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <!-- Notification Bar -->
                    <StackPane>
                        <Button fx:id="notificationButton"
                                text="🔔"
                                onAction="#handleToggleNotifications"
                                styleClass="notification-button"/>

                        <Label fx:id="notificationCountLabel"
                               text="7"
                               styleClass="notification-count"
                               StackPane.alignment="TOP_RIGHT"/>
                    </StackPane>
                </HBox>

                <!-- =========================
                     Profile Header Card
                ========================== -->
                <HBox spacing="22" styleClass="profile-header-card">

                    <StackPane styleClass="avatar-circle">
                        <Label fx:id="avatarLabel" text="HT" styleClass="avatar-text"/>
                    </StackPane>

                    <VBox spacing="8" HBox.hgrow="ALWAYS">
                        <HBox spacing="10">
                            <Label fx:id="fullNameLabel"
                                   text="Huyen Tran"
                                   styleClass="profile-name"/>

                            <Label fx:id="roleLabel"
                                   text="User"
                                   styleClass="role-pill"/>
                        </HBox>

                        <Label fx:id="emailLabel"
                               text="huyen@example.com"
                               styleClass="profile-email"/>

                        <HBox spacing="10">
                            <Label text="Rating" styleClass="small-label"/>
                            <Label fx:id="ratingLabel"
                                   text="4.8 / 5.0"
                                   styleClass="rating-pill"/>
                        </HBox>
                    </VBox>

                    <Button text="Edit Profile"
                            onAction="#handleOpenEditProfile"
                            styleClass="primary-button"/>
                </HBox>

                <!-- =========================
                     Account Summary Cards
                ========================== -->
                <HBox spacing="16" styleClass="summary-row">

                    <VBox spacing="8" styleClass="summary-card">
                        <Label text="Current Balance" styleClass="summary-title"/>
                        <Label fx:id="balanceLabel" text="0.00" styleClass="summary-value"/>
                        <Label text="Available for bidding" styleClass="summary-note"/>
                    </VBox>

                    <VBox spacing="8" styleClass="summary-card">
                        <Label text="Total Bids" styleClass="summary-title"/>
                        <Label fx:id="totalBidsLabel" text="24" styleClass="summary-value"/>
                        <Label text="Across all auctions" styleClass="summary-note"/>
                    </VBox>

                    <VBox spacing="8" styleClass="summary-card">
                        <Label text="Won Auctions" styleClass="summary-title"/>
                        <Label fx:id="wonAuctionsLabel" text="5" styleClass="summary-value"/>
                        <Label text="Completed wins" styleClass="summary-note"/>
                    </VBox>

                    <VBox spacing="8" styleClass="summary-card">
                        <Label text="Active Listings" styleClass="summary-title"/>
                        <Label fx:id="activeListingsLabel" text="3" styleClass="summary-value"/>
                        <Label text="Currently selling" styleClass="summary-note"/>
                    </VBox>

                    <VBox spacing="8" styleClass="summary-card">
                        <Label text="Rating" styleClass="summary-title"/>
                        <Label fx:id="summaryRatingLabel" text="4.8" styleClass="summary-value"/>
                        <Label text="Buyer &amp; seller score" styleClass="summary-note"/>
                    </VBox>

                </HBox>

                <!-- =========================
                     Main Tabs
                ========================== -->
                <VBox spacing="16" styleClass="content-card">

                    <HBox spacing="10">
                        <VBox spacing="4">
                            <Label fx:id="selectedTabTitleLabel"
                                   text="Overview"
                                   styleClass="section-title"/>
                            <Label text="View and manage your account information."
                                   styleClass="section-subtitle"/>
                        </VBox>
                    </HBox>

                    <TabPane fx:id="profileTabPane"
                             tabClosingPolicy="UNAVAILABLE"
                             styleClass="profile-tab-pane">

                        <!-- Overview -->
                        <Tab text="Overview">
                            <VBox spacing="18" styleClass="tab-content">

                                <HBox spacing="16">
                                    <VBox spacing="8" styleClass="overview-panel">
                                        <Label text="Account Balance" styleClass="panel-title"/>
                                        <Label fx:id="overviewBalanceLabel"
                                               text="0.00"
                                               styleClass="big-money-label"/>
                                        <Label text="Your balance is used to place bids. Top-up requests require admin approval."
                                               styleClass="panel-description"/>
                                    </VBox>

                                    <VBox spacing="8" styleClass="overview-panel">
                                        <Label text="Top-up Request" styleClass="panel-title"/>
                                        <Label fx:id="topUpStatusLabel"
                                               text="No pending request"
                                               styleClass="status-neutral"/>
                                        <Label text="Balance will only update after an administrator approves the request."
                                               styleClass="panel-description"/>
                                    </VBox>

                                    <VBox spacing="8" styleClass="overview-panel">
                                        <Label text="Recent Auction Status" styleClass="panel-title"/>
                                        <Label fx:id="recentAuctionStatusLabel"
                                               text="You are currently winning on Vintage Camera."
                                               styleClass="status-success"/>
                                        <Label text="Keep watching your active bids before the auction closes."
                                               styleClass="panel-description"/>
                                    </VBox>
                                </HBox>

                                <VBox spacing="12" styleClass="quick-actions-card">
                                    <Label text="Quick Actions" styleClass="panel-title"/>

                                    <HBox spacing="12">
                                        <Button text="Request Top-up"
                                                onAction="#handleOpenTopUp"
                                                styleClass="primary-button"/>

                                        <Button text="View Transactions"
                                                onAction="#handleGoToTransactions"
                                                styleClass="secondary-button"/>

                                        <Button text="View Watchlist"
                                                onAction="#handleGoToWatchlist"
                                                styleClass="secondary-button"/>
                                    </HBox>
                                </VBox>

                            </VBox>
                        </Tab>

                        <!-- My Listings -->
                        <Tab text="My Listings">
                            <VBox spacing="12" styleClass="tab-content">
                                <Label text="Items you are selling as a seller." styleClass="table-hint"/>

                                <TableView fx:id="listingsTable" styleClass="modern-table">
                                    <columns>
                                        <TableColumn fx:id="listingItemNameColumn" text="Item Name" prefWidth="220"/>
                                        <TableColumn fx:id="listingStartingPriceColumn" text="Starting Price" prefWidth="140"/>
                                        <TableColumn fx:id="listingCurrentBidColumn" text="Current Bid" prefWidth="140"/>
                                        <TableColumn fx:id="listingStatusColumn" text="Status" prefWidth="140"/>
                                        <TableColumn fx:id="listingCreatedDateColumn" text="Created Date" prefWidth="160"/>
                                    </columns>
                                </TableView>
                            </VBox>
                        </Tab>

                        <!-- My Bids -->
                        <Tab text="My Bids">
                            <VBox spacing="12" styleClass="tab-content">
                                <Label text="Auctions where you have placed bids as a buyer." styleClass="table-hint"/>

                                <TableView fx:id="bidsTable" styleClass="modern-table">
                                    <columns>
                                        <TableColumn fx:id="bidItemNameColumn" text="Item Name" prefWidth="220"/>
                                        <TableColumn fx:id="bidMyAmountColumn" text="My Bid" prefWidth="130"/>
                                        <TableColumn fx:id="bidHighestAmountColumn" text="Highest Bid" prefWidth="140"/>
                                        <TableColumn fx:id="bidStatusColumn" text="Status" prefWidth="130"/>
                                        <TableColumn fx:id="bidDateColumn" text="Bid Date" prefWidth="170"/>
                                    </columns>
                                </TableView>
                            </VBox>
                        </Tab>

                        <!-- Watchlist -->
                        <Tab text="Watchlist">
                            <VBox spacing="12" styleClass="tab-content">
                                <Label text="Items you are interested in and want to monitor." styleClass="table-hint"/>

                                <TableView fx:id="watchlistTable" styleClass="modern-table">
                                    <columns>
                                        <TableColumn fx:id="watchItemNameColumn" text="Item Name" prefWidth="220"/>
                                        <TableColumn fx:id="watchCurrentPriceColumn" text="Current Price" prefWidth="140"/>
                                        <TableColumn fx:id="watchTimeRemainingColumn" text="Time Remaining" prefWidth="160"/>
                                        <TableColumn fx:id="watchStatusColumn" text="Status" prefWidth="140"/>
                                        <TableColumn fx:id="watchActionColumn" text="Action" prefWidth="120"/>
                                    </columns>
                                </TableView>
                            </VBox>
                        </Tab>

                        <!-- Transactions -->
                        <Tab text="Transactions">
                            <VBox spacing="12" styleClass="tab-content">
                                <Label text="Your purchase and sale transaction history." styleClass="table-hint"/>

                                <TableView fx:id="transactionsTable" styleClass="modern-table">
                                    <columns>
                                        <TableColumn fx:id="transactionDateColumn" text="Date" prefWidth="160"/>
                                        <TableColumn fx:id="transactionTypeColumn" text="Type" prefWidth="130"/>
                                        <TableColumn fx:id="transactionItemColumn" text="Item" prefWidth="220"/>
                                        <TableColumn fx:id="transactionAmountColumn" text="Amount" prefWidth="140"/>
                                        <TableColumn fx:id="transactionStatusColumn" text="Status" prefWidth="150"/>
                                    </columns>
                                </TableView>
                            </VBox>
                        </Tab>

                        <!-- Activity Log -->
                        <Tab text="Activity Log">
                            <VBox spacing="12" styleClass="tab-content">
                                <Label text="Your personal activity history inside BidBlitz." styleClass="table-hint"/>

                                <TableView fx:id="activityTable" styleClass="modern-table">
                                    <columns>
                                        <TableColumn fx:id="activityDateTimeColumn" text="Date / Time" prefWidth="180"/>
                                        <TableColumn fx:id="activityActionColumn" text="Action" prefWidth="160"/>
                                        <TableColumn fx:id="activityDescriptionColumn" text="Description" prefWidth="420"/>
                                    </columns>
                                </TableView>
                            </VBox>
                        </Tab>

                    </TabPane>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>
</BorderPane>