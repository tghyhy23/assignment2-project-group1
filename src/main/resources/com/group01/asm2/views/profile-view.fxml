<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.image.ImageView?>
<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.group01.asm2.controllers.ProfileController"
           stylesheets="@../styles/views/profile.css"
           styleClass="profile-root">

    <ScrollPane fx:id="profileScrollPane"
                fitToWidth="true"
                hbarPolicy="NEVER"
                vbarPolicy="AS_NEEDED"
                styleClass="profile-scroll">

        <VBox spacing="24" styleClass="profile-container">

            <padding>
                <Insets top="30" right="40" bottom="30" left="40"/>
            </padding>

            <VBox spacing="4">
                <Label text="Profile" styleClass="page-title"/>
                <Label text="Manage your BidBlitz account and auction listings."
                       styleClass="page-subtitle"/>
            </VBox>

            <HBox spacing="0"
                  alignment="CENTER_LEFT"
                  styleClass="profile-header-card">

                <!-- LEFT GROUP: Avatar + Basic Info -->
                <HBox spacing="38"
                      alignment="CENTER_LEFT"
                      styleClass="profile-left-group">

                    <VBox spacing="10"
                          alignment="CENTER"
                          styleClass="profile-avatar-section">

                        <StackPane styleClass="avatar-gradient-circle">
                            <Label fx:id="avatarLabel"
                                   text=""
                                   styleClass="avatar-initials"/>
                        </StackPane>
                    </VBox>

                    <VBox spacing="14"
                          alignment="CENTER_LEFT"
                          styleClass="profile-basic-info">

                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Label fx:id="fullNameLabel"
                                   text=""
                                   styleClass="profile-full-name"/>

                            <Label fx:id="roleLabel"
                                   text=""
                                   styleClass="role-pill"/>
                        </HBox>

                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Label fx:id="emailLabel"
                                   text=""
                                   styleClass="profile-email"/>

                            <Label fx:id="ratingLabel"
                                   text=""
                                   styleClass="rating-pill"/>
                        </HBox>
                    </VBox>
                </HBox>

                <!-- Flexible space between left group and private info -->
                <Region HBox.hgrow="ALWAYS"/>

                <!-- MIDDLE GROUP: Private Details -->
                <HBox spacing="14"
                      alignment="CENTER_LEFT"
                      styleClass="private-details-flex">

                    <VBox spacing="12" styleClass="private-details-column">
                        <VBox spacing="4" styleClass="private-info-box">
                            <Label text="Phone" styleClass="private-info-label"/>
                            <Label fx:id="phoneLabel" text="" styleClass="private-info-value"/>
                        </VBox>

                        <VBox spacing="4" styleClass="private-info-box">
                            <Label text="Address" styleClass="private-info-label"/>
                            <Label fx:id="addressLabel" text="" wrapText="true" styleClass="private-info-value"/>
                        </VBox>
                    </VBox>

                    <VBox spacing="12" styleClass="private-details-column">
                        <VBox spacing="4" styleClass="private-info-box">
                            <Label text="Date of Birth" styleClass="private-info-label"/>
                            <Label fx:id="dateOfBirthLabel" text="" styleClass="private-info-value"/>
                        </VBox>

                        <VBox spacing="4" styleClass="private-info-box">
                            <Label text="Joined Date" styleClass="private-info-label"/>
                            <Label fx:id="joinedDateLabel" text="" styleClass="private-info-value"/>
                        </VBox>
                    </VBox>
                </HBox>

                <!-- Space between private info and edit button -->
                <Region minWidth="80" prefWidth="100"/>

                <!-- RIGHT GROUP: Edit Button -->
                <VBox alignment="CENTER_RIGHT"
                      styleClass="profile-action-section">
                    <Button fx:id="editProfileButton"
                            text="Edit Profile"
                            onAction="#handleOpenEditProfile"
                            styleClass="edit-profile-button"/>
                </VBox>

            </HBox>
            <HBox fx:id="summaryRow" spacing="16" styleClass="summary-row">
                <VBox spacing="8" styleClass="summary-card">
                    <Label text="Current Balance" styleClass="summary-title"/>
                    <Label fx:id="balanceLabel" text="0.00" styleClass="summary-value"/>
                    <Label text="Available for bidding" styleClass="summary-note"/>
                </VBox>

                <VBox spacing="8" styleClass="summary-card">
                    <Label text="Total Listings" styleClass="summary-title"/>
                    <Label fx:id="totalListingsLabel" text="0" styleClass="summary-value"/>
                    <Label text="All listed auction items" styleClass="summary-note"/>
                </VBox>

                <VBox spacing="8" styleClass="summary-card">
                    <Label text="Active Listings" styleClass="summary-title"/>
                    <Label fx:id="activeListingsLabel" text="0" styleClass="summary-value"/>
                    <Label text="Currently selling" styleClass="summary-note"/>
                </VBox>

                <VBox spacing="8" styleClass="summary-card">
                    <Label text="Sold Listings" styleClass="summary-title"/>
                    <Label fx:id="soldListingsLabel" text="0" styleClass="summary-value"/>
                    <Label text="Completed auctions" styleClass="summary-note"/>
                </VBox>

                <VBox spacing="8" styleClass="summary-card">
                    <Label text="Rating" styleClass="summary-title"/>
                    <Label fx:id="summaryRatingLabel" text="4.8" styleClass="summary-value"/>
                    <Label text="Buyer &amp; seller score" styleClass="summary-note"/>
                </VBox>
            </HBox>

            <VBox spacing="16" styleClass="content-card">
                <HBox spacing="10">
                    <VBox spacing="4">
                        <Label fx:id="selectedTabTitleLabel"
                               text="Wallet"
                               styleClass="section-title"/>
                        <Label text="View and manage your profile content."
                               styleClass="section-subtitle"/>
                    </VBox>
                </HBox>

                <TabPane fx:id="profileTabPane"
                         tabClosingPolicy="UNAVAILABLE"
                         styleClass="profile-tab-pane"
                         VBox.vgrow="NEVER">

                    <Tab text="Wallet">
                        <VBox spacing="18" styleClass="tab-content">

                            <HBox fx:id="walletPanelRow" spacing="16">
                                <VBox spacing="8" styleClass="wallet-panel">
                                    <Label text="Account Balance" styleClass="panel-title"/>
                                    <Label fx:id="walletBalanceLabel"
                                           text="0.00"
                                           styleClass="big-money-label"/>
                                    <Label text="Your balance is used to place bids. Top-up requests require admin approval."
                                           wrapText="true"
                                           styleClass="panel-description"/>
                                </VBox>

                                <VBox spacing="8" styleClass="wallet-panel">
                                    <Label text="Top-up Request" styleClass="panel-title"/>
                                    <Label fx:id="topUpStatusLabel"
                                           text="No pending request"
                                           styleClass="status-neutral"/>
                                    <Label text="Balance will only update after an administrator approves the request."
                                           wrapText="true"
                                           styleClass="panel-description"/>
                                </VBox>

                                <VBox spacing="8" styleClass="wallet-panel">
                                    <Label text="Recent Auction Status" styleClass="panel-title"/>
                                    <Label fx:id="recentAuctionStatusLabel"
                                           text="No recent auction update."
                                           styleClass="status-success"/>
                                    <Label text="Auction activity is tracked separately in My Bids and Watchlist pages."
                                           wrapText="true"
                                           styleClass="panel-description"/>
                                </VBox>
                            </HBox>

                            <VBox spacing="12" styleClass="quick-actions-card">
                                <Label text="Quick Actions" styleClass="panel-title"/>

                                <HBox spacing="12">
                                    <Button text="Request Top-up"
                                            onAction="#handleOpenTopUp"
                                            styleClass="primary-button"/>
                                </HBox>
                            </VBox>
                        </VBox>
                    </Tab>

                    <Tab text="My Listings">
                        <VBox spacing="18" styleClass="tab-content listings-section">

                            <fx:include fx:id="profileListings"
                                        source="./components/all_auctions.fxml"/>
                        </VBox>
                    </Tab>

                    <Tab text="Activity Log">
                        <VBox spacing="12" styleClass="tab-content">
                            <Label text="Your personal activity history inside BidBlitz."
                                   styleClass="table-hint"/>

                            <TableView fx:id="activityTable" styleClass="modern-table">
                                <columns>
                                    <TableColumn fx:id="activityDateTimeColumn" text="Date / Time"/>
                                    <TableColumn fx:id="activityActionColumn" text="Action"/>
                                    <TableColumn fx:id="activityDescriptionColumn" text="Description"/>
                                </columns>
                            </TableView>
                        </VBox>
                    </Tab>

                    <Tab fx:id="sellerStatisticsTab" text="Seller Statistics">
                        <VBox spacing="18" styleClass="tab-content seller-stats-section">

                            <HBox spacing="16" styleClass="seller-stats-summary-row">
                                <VBox spacing="8" styleClass="summary-card">
                                    <Label text="Items Sold" styleClass="summary-title"/>
                                    <Label fx:id="itemsSoldLabel" text="0" styleClass="summary-value"/>
                                    <Label text="Completed successful sales" styleClass="summary-note"/>
                                </VBox>

                                <VBox spacing="8" styleClass="summary-card">
                                    <Label text="Total Revenue" styleClass="summary-title"/>
                                    <Label fx:id="totalRevenueLabel" text="0.00" styleClass="summary-value"/>
                                    <Label text="Total amount earned from sold items" styleClass="summary-note"/>
                                </VBox>

                                <VBox spacing="8" styleClass="summary-card">
                                    <Label text="Commission Fees" styleClass="summary-title"/>
                                    <Label fx:id="commissionFeesLabel" text="0.00" styleClass="summary-value"/>
                                    <Label text="Platform fees paid on completed sales" styleClass="summary-note"/>
                                </VBox>

                                <VBox spacing="8" styleClass="summary-card">
                                    <Label text="Sold Ratio" styleClass="summary-title"/>
                                    <Label fx:id="soldRatioLabel" text="0%" styleClass="summary-value"/>
                                    <Label text="Sold vs unsold listing performance" styleClass="summary-note"/>
                                </VBox>
                            </HBox>

                            <HBox spacing="18" styleClass="seller-stats-chart-row">
                                <VBox spacing="12" styleClass="content-card" HBox.hgrow="ALWAYS">
                                    <Label text="Average Sale Price by Category" styleClass="section-title"/>
                                    <BarChart fx:id="averageSalePriceChart"
                                              categoryGap="18"
                                              barGap="4"
                                              legendVisible="false"
                                              animated="false"
                                              prefHeight="320">
                                        <xAxis>
                                            <CategoryAxis label="Category"/>
                                        </xAxis>
                                        <yAxis>
                                            <NumberAxis label="Average Price"/>
                                        </yAxis>
                                    </BarChart>
                                </VBox>

                            </HBox>

                            <VBox spacing="12" styleClass="content-card">
                                <Label text="Performance Trend Overview" styleClass="section-title"/>
                                <LineChart fx:id="listingTrendChart"
                                           createSymbols="false"
                                           animated="false"
                                           prefHeight="320">
                                    <xAxis>
                                        <CategoryAxis label="Month"/>
                                    </xAxis>
                                    <yAxis>
                                        <NumberAxis label="Listings"/>
                                    </yAxis>
                                </LineChart>
                            </VBox>

                        </VBox>
                    </Tab>

                </TabPane>
            </VBox>
        </VBox>
    </ScrollPane>

    <StackPane fx:id="editProfileOverlay"
               visible="false"
               managed="false"
               styleClass="modal-overlay">

        <VBox fx:id="editProfileModal"
              spacing="18"
              alignment="TOP_LEFT"
              styleClass="add-listing-modal"
              maxHeight="-Infinity">

            <VBox spacing="6" alignment="TOP_LEFT">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Edit Profile" styleClass="modal-title"/>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Button text="✕"
                            onAction="#handleCloseEditProfile"
                            styleClass="modal-close-button"/>
                </HBox>

                <Label text="Update your profile details."
                       styleClass="modal-subtitle"/>
            </VBox>

            <VBox spacing="16" styleClass="modal-form">
                <VBox spacing="6">
                    <Label text="Full Name" styleClass="form-label"/>
                    <TextField fx:id="editFullNameField"
                               promptText="Enter full name"
                               styleClass="form-input"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Email" styleClass="form-label"/>
                    <TextField fx:id="editEmailField"
                               promptText="Enter email"
                               styleClass="form-input"/>
                </VBox>

                <HBox spacing="14">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Phone" styleClass="form-label"/>
                        <TextField fx:id="editPhoneField"
                                   promptText="Enter phone number"
                                   styleClass="form-input"/>
                    </VBox>

                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Date of Birth" styleClass="form-label"/>
                        <DatePicker fx:id="editDateOfBirthPicker"
                                    promptText="Select date of birth"
                                    maxWidth="Infinity"
                                    styleClass="form-input"/>                    </VBox>
                </HBox>

                <VBox spacing="6">
                    <Label text="Address" styleClass="form-label"/>
                    <TextField fx:id="editAddressField"
                               promptText="Enter address"
                               styleClass="form-input"/>
                </VBox>
            </VBox>

            <HBox spacing="12"
                  alignment="CENTER_RIGHT"
                  styleClass="modal-footer">

                <Button text="Cancel"
                        onAction="#handleCloseEditProfile"
                        styleClass="modal-cancel-button"/>

                <Button text="Save Changes"
                        onAction="#handleSaveEditProfile"
                        styleClass="modal-save-button"/>
            </HBox>
        </VBox>
    </StackPane>

    <StackPane fx:id="addListingOverlay"
               visible="false"
               managed="false"
               styleClass="modal-overlay">

        <VBox fx:id="addListingModal"
              spacing="18"
              styleClass="add-listing-modal"
              maxHeight="-Infinity">

            <VBox spacing="6" alignment="TOP_LEFT">

                <HBox spacing="10" alignment="CENTER_LEFT">

                    <Label text="Add New Auction Item"
                           styleClass="modal-title"/>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Button text="✕"
                            onAction="#handleCloseAddListing"
                            styleClass="modal-close-button"/>

                </HBox>

                <Label text="Create a new item for your listing collection."
                       styleClass="modal-subtitle"/>

            </VBox>

            <VBox spacing="12">

                <!-- Title -->
                <VBox spacing="6">
                    <Label text="Title *" styleClass="form-label"/>
                    <TextField fx:id="addListingTitleField"
                               promptText="Example: Vintage Watch"
                               styleClass="form-input"/>
                </VBox>

                <!-- Description -->
                <VBox spacing="6">
                    <Label text="Description *" styleClass="form-label"/>
                    <TextArea fx:id="addListingDescriptionArea"
                              promptText="Describe the item, its features, and important details..."
                              wrapText="true"
                              prefRowCount="4"
                              styleClass="form-input"/>
                </VBox>

                <!-- Category + Condition -->
                <HBox spacing="14">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Category" styleClass="form-label"/>
                        <ComboBox fx:id="addListingCategoryComboBox"
                                  maxWidth="Infinity"
                                  styleClass="form-combo"/>
                    </VBox>

                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Condition" styleClass="form-label"/>
                        <ComboBox fx:id="addListingConditionComboBox"
                                  maxWidth="Infinity"
                                  styleClass="form-combo"/>
                    </VBox>
                </HBox>

                <!-- Starting Price + Reserve Price -->
                <HBox spacing="14">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Starting Price *" styleClass="form-label"/>
                        <TextField fx:id="addListingStartingPriceField"
                                   promptText="Example: 450.00"
                                   styleClass="form-input"/>
                    </VBox>

                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Reserve Price (Optional)" styleClass="form-label"/>
                        <TextField fx:id="addListingReservePriceField"
                                   promptText="Example: 600.00"
                                   styleClass="form-input"/>
                    </VBox>
                </HBox>

                <!-- Item Image Upload -->
                <VBox spacing="8">
                    <Label text="Item Image *" styleClass="form-label"/>

                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <Button text="Upload Image"
                                onAction="#handleUploadListingImage"
                                styleClass="modal-cancel-button"/>

                        <Label fx:id="addListingImageNameLabel"
                               text="No image selected"
                               styleClass="image-file-name"/>
                    </HBox>

                    <StackPane fx:id="addListingImagePreviewBox"
                               visible="false"
                               managed="false"
                               styleClass="image-preview-box">
                        <ImageView fx:id="addListingImagePreview"
                                   fitWidth="180"
                                   fitHeight="120"
                                   preserveRatio="true"
                                   smooth="true"/>
                    </StackPane>
                </VBox>

                <Label fx:id="addListingErrorLabel"
                       text=""
                       styleClass="error-label"/>

            </VBox>

            <HBox spacing="12"
                  alignment="CENTER_RIGHT"
                  styleClass="modal-footer">

                <Button text="Cancel"
                        onAction="#handleCloseAddListing"
                        styleClass="modal-cancel-button"/>

                <Button text="Save Item"
                        onAction="#handleSaveListing"
                        styleClass="modal-save-button"/>
            </HBox>
        </VBox>
    </StackPane>

    <StackPane fx:id="topUpOverlay"
               visible="false"
               managed="false"
               styleClass="modal-overlay">

        <VBox fx:id="topUpModal"
              spacing="22"
              alignment="TOP_LEFT"
              styleClass="edit-profile-modal"
              maxHeight="-Infinity">

            <!-- Header -->
            <HBox alignment="CENTER_LEFT"
                  spacing="12"
                  styleClass="modal-header">

                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Request Account Top-up"
                           styleClass="modal-title"/>

                    <Label text="Enter the amount you want to add. Your request will be sent to an administrator for approval."
                           wrapText="true"
                           styleClass="modal-subtitle"/>
                </VBox>

                <Button text="✕"
                        onAction="#handleCloseTopUp"
                        styleClass="modal-close-button"/>
            </HBox>

            <!-- Form -->
            <VBox spacing="16"
                  styleClass="modal-form">

                <VBox spacing="6">
                    <Label text="Top-up Amount"
                           styleClass="form-label"/>

                    <TextField fx:id="topUpAmountField"
                               promptText="Enter amount between 10 and 5000"
                               styleClass="form-input"/>
                </VBox>

                <Label fx:id="topUpErrorLabel"
                       text=""
                       styleClass="error-label"/>
            </VBox>

            <!-- Footer -->
            <HBox spacing="12"
                  alignment="CENTER_RIGHT"
                  styleClass="modal-footer">

                <Button text="Cancel"
                        onAction="#handleCloseTopUp"
                        styleClass="modal-cancel-button"/>

                <Button text="Submit Request"
                        onAction="#handleSubmitTopUp"
                        styleClass="modal-save-button"/>
            </HBox>

        </VBox>
    </StackPane>
</StackPane>