<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.group01.asm2.controllers.AuctionsController"
      spacing="16"
      stylesheets="@../styles/views/auctions.css"
      styleClass="auctions-root">

    <padding>
        <Insets top="24" right="24" bottom="24" left="24"/>
    </padding>

    <Label text="Auction History" styleClass="page-title"/>
    <Label text="View your recent purchases and sales." styleClass="page-subtitle"/>

    <VBox styleClass="content-card" VBox.vgrow="ALWAYS">
        <TableView fx:id="auctionsTable" styleClass="modern-table">
            <columns>
                <TableColumn fx:id="auctionDateColumn" text="Date" prefWidth="120"/>
                <TableColumn fx:id="auctionTypeColumn" text="Type" prefWidth="100"/>
                <TableColumn fx:id="auctionItemColumn" text="Item" prefWidth="200"/>
                <TableColumn fx:id="auctionAmountColumn" text="Amount" prefWidth="120"/>
                <TableColumn fx:id="auctionStatusColumn" text="Status" prefWidth="150"/>
            </columns>
        </TableView>
    </VBox>

</VBox>